<%- include('../partials/admin-header', { pageTitle: 'Dashboard', pendingBookings: stats.pendingBookings }) %>

<div class="adm-page-header">
  <div>
    <h1 class="adm-page-title">Dashboard</h1>
    <p class="adm-page-subtitle">Tổng quan hoạt động TaiLand Cafe</p>
  </div>
  <div class="adm-page-actions">
    <div class="adm-gh-badge <%= ghStatus.connected ? 'ok' : 'err' %>">
      <span class="adm-gh-dot"></span>
      <% if (ghStatus.connected) { %>GitHub: <strong><%= ghStatus.user %></strong><% } else { %>GitHub: Chưa kết nối<% } %>
    </div>
    <form action="/admin/sync" method="POST" style="margin:0">
      <button type="submit" class="adm-btn adm-btn-github" onclick="this.disabled=true;this.textContent='Đang sync...'">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
        Sync GitHub
      </button>
    </form>
  </div>
</div>

<div class="adm-stats-grid">
  <div class="adm-stat">
    <div class="adm-stat-header">
      <div class="adm-stat-icon green"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
      <% if (stats.pendingBookings > 0) { %><span class="adm-stat-trend warn"><%= stats.pendingBookings %> cho</span><% } else { %><span class="adm-stat-trend neu">OK</span><% } %>
    </div>
    <div class="adm-stat-val"><%= stats.totalBookings %></div>
    <div class="adm-stat-label">Tong dat ban</div>
    <div class="adm-stat-sub"><%= stats.pendingBookings %> cho xu ly</div>
  </div>
  <div class="adm-stat">
    <div class="adm-stat-header">
      <div class="adm-stat-icon gold"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/></svg></div>
      <span class="adm-stat-trend up">Active</span>
    </div>
    <div class="adm-stat-val"><%= stats.menuItems %></div>
    <div class="adm-stat-label">Mon trong menu</div>
    <div class="adm-stat-sub">Ca phe - Tra sua - Sinh to - Banh</div>
  </div>
  <div class="adm-stat">
    <div class="adm-stat-header">
      <div class="adm-stat-icon blue"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
      <span class="adm-stat-trend neu">VI / EN</span>
    </div>
    <div class="adm-stat-val"><%= stats.blogPosts %></div>
    <div class="adm-stat-label">Bai viet blog</div>
    <div class="adm-stat-sub">Song ngu Viet - Anh</div>
  </div>
  <div class="adm-stat">
    <div class="adm-stat-header">
      <div class="adm-stat-icon purple"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
      <span class="adm-stat-trend up">Active</span>
    </div>
    <div class="adm-stat-val"><%= stats.branches %></div>
    <div class="adm-stat-label">Chi nhanh</div>
    <div class="adm-stat-sub">Dang hoat dong</div>
  </div>
</div>

<% if (!ghStatus.connected) { %>
<div class="adm-notice warn">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
  <div class="adm-notice-body">
    <p><strong>GitHub chua ket noi</strong> - Them vao file <code>.env</code>:</p>
    <pre>GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_OWNER=ThanhTaiNguyenGT
GITHUB_REPO=tailandcoffee
GITHUB_BRANCH=main</pre>
    <p>Tao token tai <a href="https://github.com/settings/tokens/new" target="_blank" rel="noopener">github.com/settings/tokens/new</a> - tick <strong>repo</strong> - Generate token - <code>pm2 restart tailand-cafe</code></p>
  </div>
</div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
  <div class="adm-card">
    <div class="adm-card-header">
      <span class="adm-card-title">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Truy cap nhanh
      </span>
    </div>
    <div class="adm-card-body">
      <div class="adm-tiles">
        <a href="/admin/menu" class="adm-tile">
          <div class="adm-tile-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/></svg></div>
          <div class="adm-tile-label">Quan ly Menu</div>
          <div class="adm-tile-sub"><%= stats.menuItems %> mon</div>
        </a>
        <a href="/admin/bookings" class="adm-tile">
          <div class="adm-tile-icon" style="background:rgba(5,150,105,.1);color:#059669"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          <div class="adm-tile-label">Dat ban <% if (stats.pendingBookings > 0) { %><span class="adm-nav-badge" style="font-size:.62rem;padding:1px 6px;display:inline-flex"><%= stats.pendingBookings %></span><% } %></div>
          <div class="adm-tile-sub"><%= stats.totalBookings %> tong cong</div>
        </a>
        <a href="/admin/blog" class="adm-tile">
          <div class="adm-tile-icon" style="background:rgba(59,130,246,.1);color:#3B82F6"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
          <div class="adm-tile-label">Viet Blog</div>
          <div class="adm-tile-sub"><%= stats.blogPosts %> bai viet</div>
        </a>
        <a href="/?lang=vi" target="_blank" rel="noopener" class="adm-tile">
          <div class="adm-tile-icon" style="background:rgba(139,92,246,.1);color:#8B5CF6"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
          <div class="adm-tile-label">Xem website</div>
          <div class="adm-tile-sub">Mo tab moi</div>
        </a>
      </div>
    </div>
  </div>

  <div class="adm-card">
    <div class="adm-card-header">
      <span class="adm-card-title">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>
        Luong dong bo GitHub
      </span>
    </div>
    <div class="adm-card-body">
      <div class="adm-flow" style="margin-bottom:14px">
        <div class="adm-flow-step green">Admin them</div>
        <svg class="adm-flow-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <div class="adm-flow-step blue">Luu JSON<span>data/*.json</span></div>
        <svg class="adm-flow-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <div class="adm-flow-step dark">GitHub<span>auto commit</span></div>
        <svg class="adm-flow-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <div class="adm-flow-step yellow">Website<span>cap nhat</span></div>
      </div>
      <p style="font-size:.78rem;color:var(--adm-text-3);line-height:1.6">Deploy server moi: <code style="background:#F3F4F6;padding:2px 6px;border-radius:4px;font-size:.75rem">git pull origin main</code> lay ngay data moi nhat.</p>
    </div>
  </div>
</div>

<%- include('../partials/admin-footer') %>
