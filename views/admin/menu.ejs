<%- include('../partials/admin-header', { pageTitle: 'Menu' }) %>

<div class="adm-page-header">
  <div>
    <h1 class="adm-page-title">Quan ly Menu</h1>
    <p class="adm-page-subtitle"><%= items.length %> mon trong thuc don</p>
  </div>
  <a href="/admin" class="adm-btn adm-btn-outline adm-btn-sm">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    Dashboard
  </a>
</div>

<!-- Form them mon -->
<div class="adm-card" style="margin-bottom:20px">
  <div class="adm-collapsible-header" id="formHeader" onclick="toggleForm()">
    <span class="adm-card-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Them mon moi
    </span>
    <svg id="formChevron" class="adm-collapsible-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
  </div>
  <div id="addForm" class="adm-collapsible-body">
    <form action="/admin/menu/add" method="POST" id="menuAddForm">
      <div class="adm-form-row">
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Ten mon (Tieng Viet) <span class="adm-required">*</span></label>
          <input class="adm-input" type="text" name="name_vi" required placeholder="Bac Xiu TaiLand">
        </div>
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Name (English) <span class="adm-required">*</span></label>
          <input class="adm-input" type="text" name="name_en" required placeholder="TaiLand White Coffee">
        </div>
      </div>
      <div class="adm-form-row">
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Mo ta (VI) <span class="adm-label-opt">tuy chon</span></label>
          <textarea class="adm-textarea" name="desc_vi" rows="2" placeholder="Ca phe sua truyen thong..."></textarea>
        </div>
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Description (EN) <span class="adm-label-opt">optional</span></label>
          <textarea class="adm-textarea" name="desc_en" rows="2" placeholder="Traditional Vietnamese..."></textarea>
        </div>
      </div>
      <div class="adm-form-row">
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Tag nhan (VI) <span class="adm-label-opt">tuy chon</span></label>
          <input class="adm-input" type="text" name="tag_vi" placeholder="Ban chay / Moi / Yeu thich">
        </div>
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Tag label (EN) <span class="adm-label-opt">optional</span></label>
          <input class="adm-input" type="text" name="tag_en" placeholder="Best Seller / New / Favorite">
        </div>
      </div>
      <div class="adm-form-row-3">
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Gia (VND) <span class="adm-required">*</span></label>
          <input class="adm-input" type="number" name="price" required min="1000" step="1000" placeholder="45000">
        </div>
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Danh muc <span class="adm-required">*</span></label>
          <select class="adm-select" name="category" required>
            <% categories.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name_vi %></option>
            <% }) %>
          </select>
        </div>
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Hien thi noi bat</label>
          <select class="adm-select" name="featured">
            <option value="">Khong</option>
            <option value="on">Co (hien trang chu)</option>
          </select>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:12px;padding-top:4px">
        <button type="submit" class="adm-btn adm-btn-accent" id="submitBtn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Them mon & Sync GitHub
        </button>
        <span style="font-size:.75rem;color:var(--adm-text-3)">Tu dong commit len GitHub sau khi them</span>
      </div>
    </form>
  </div>
</div>

<!-- Bang danh sach -->
<div class="adm-card">
  <div class="adm-card-header">
    <span class="adm-card-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      Danh sach mon (<%= items.length %>)
    </span>
  </div>
  <% if (items.length === 0) { %>
  <div class="adm-empty">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/></svg>
    <p>Menu chua co mon nao</p>
    <span>Them mon dau tien phia tren</span>
  </div>
  <% } else { %>
  <div class="adm-table-wrap">
    <table class="adm-table">
      <thead>
        <tr>
          <th>#</th>
          <th style="width:68px">Hinh</th>
          <th>Ten VI / EN</th>
          <th>Danh muc</th>
          <th>Gia</th>
          <th>Tag</th>
          <th>Noi bat</th>
          <th style="width:110px">Thao tac</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach((item, idx) => { %>
        <% const hasImg = item.image && item.image !== '/images/menu/default.jpg'; %>
        <tr>
          <td style="color:var(--adm-text-3);font-size:.78rem"><%= idx + 1 %></td>
          <td style="padding:10px 12px">
            <div style="position:relative;width:52px;height:52px">
              <% if (hasImg) { %>
              <img src="<%= item.image %>" alt="<%= item.name_vi %>"
                style="width:52px;height:52px;object-fit:cover;border-radius:8px;border:1px solid var(--adm-border);display:block">
              <% } else { %>
              <div style="width:52px;height:52px;border-radius:8px;background:#F9FAFB;border:1.5px dashed #D1D5DB;display:flex;align-items:center;justify-content:center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C9A96E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
              <% } %>
              <label for="imgUp_<%= item.id %>" title="Bam de thay hinh"
                style="position:absolute;inset:0;cursor:pointer;border-radius:8px;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0);transition:background .18s"
                onmouseover="this.style.background='rgba(0,0,0,.5)';this.querySelector('.uico').style.opacity=1"
                onmouseout="this.style.background='rgba(0,0,0,0)';this.querySelector('.uico').style.opacity=0">
                <span class="uico" style="opacity:0;transition:opacity .18s;display:flex;align-items:center;justify-content:center">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                </span>
              </label>
              <form id="imgForm_<%= item.id %>" action="/admin/menu/<%= item.id %>/image" method="POST" enctype="multipart/form-data" style="display:none">
                <input type="file" id="imgUp_<%= item.id %>" name="image" accept="image/jpeg,image/png,image/webp,image/gif"
                  onchange="document.getElementById('imgForm_<%= item.id %>').submit()">
              </form>
            </div>
          </td>
          <td>
            <div style="font-weight:600;font-size:.88rem;color:var(--adm-text)"><%= item.name_vi %></div>
            <div style="font-size:.75rem;color:var(--adm-text-3);margin-top:2px"><%= item.name_en %></div>
          </td>
          <td><span class="adm-badge adm-badge-dark"><%= categories.find(c=>c.id===item.category)?.name_vi || item.category %></span></td>
          <td style="font-weight:700;font-size:.88rem"><%= item.price.toLocaleString('vi-VN') %>d</td>
          <td style="font-size:.78rem;color:var(--adm-text-3)"><%= item.tag_vi || '—' %></td>
          <td>
            <% if (item.featured) { %>
            <span class="adm-badge adm-badge-yellow">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Noi bat
            </span>
            <% } else { %>
            <span style="color:var(--adm-border);font-size:.78rem">—</span>
            <% } %>
          </td>
          <td>
            <div style="display:flex;flex-direction:column;gap:5px">
              <a href="/admin/menu/<%= item.id %>/edit" class="adm-btn adm-btn-outline adm-btn-sm" style="width:100%;justify-content:center;font-size:.7rem">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Sua
              </a>
              <% if (hasImg) { %>
              <form action="/admin/menu/<%= item.id %>/image/delete" method="POST"
                onsubmit="return confirm('Xoa hinh cua mon nay?')">
                <button type="submit" class="adm-btn adm-btn-ghost adm-btn-sm" style="width:100%;justify-content:center;font-size:.7rem">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                  Xoa hinh
                </button>
              </form>
              <% } %>
              <form action="/admin/menu/<%= item.id %>/delete" method="POST"
                onsubmit="return confirm('Xoa mon nay? Hanh dong se dong thoi xoa tren GitHub.')">
                <button type="submit" class="adm-btn adm-btn-danger adm-btn-sm" style="width:100%;justify-content:center;font-size:.7rem">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
                  Xoa mon
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
function toggleForm() {
  const body = document.getElementById('addForm');
  const header = document.getElementById('formHeader');
  const chevron = document.getElementById('formChevron');
  const open = body.classList.contains('open');
  body.classList.toggle('open', !open);
  header.classList.toggle('open', !open);
}
document.getElementById('menuAddForm')?.addEventListener('submit', function() {
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="animation:spin 1s linear infinite"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg> Dang luu & sync...';
});
</script>
<style>@keyframes spin { to { transform: rotate(360deg); } }</style>

<%- include('../partials/admin-footer') %>
