<%- include('../partials/admin-header', { pageTitle: 'Menu' }) %>

<div class="admin-content">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px">
    <h1 class="admin-page-title" style="margin:0">Menu (<%= items.length %> món)</h1>
    <a href="/admin" class="btn btn-sm btn-outline">← Dashboard</a>
  </div>

  <% if (success && success.length) { %>
  <div class="flash flash-success">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
    <%= success[0] %>
  </div>
  <% } %>
  <% if (error && error.length) { %>
  <div class="flash flash-error">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <%= error[0] %>
  </div>
  <% } %>

  <!-- Add Item Form -->
  <div class="admin-card" style="margin-bottom:20px">
    <div class="admin-card-header" style="cursor:pointer" onclick="toggleForm()">
      <span class="admin-card-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:6px" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Thêm món mới
      </span>
      <svg id="formChevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition:.2s" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
    <div id="addForm" style="display:none">
      <div class="admin-card-body">
        <form action="/admin/menu/add" method="POST" id="menuAddForm">
          <!-- Tên -->
          <div class="form-row" style="margin-bottom:16px">
            <div class="form-group" style="margin:0">
              <label class="form-label">Tên món (Tiếng Việt) <span class="form-required">*</span></label>
              <input class="form-input" type="text" name="name_vi" required placeholder="Bạc Xỉu TaiLand">
            </div>
            <div class="form-group" style="margin:0">
              <label class="form-label">Name (English) <span class="form-required">*</span></label>
              <input class="form-input" type="text" name="name_en" required placeholder="TaiLand White Coffee">
            </div>
          </div>
          <!-- Mô tả -->
          <div class="form-row" style="margin-bottom:16px">
            <div class="form-group" style="margin:0">
              <label class="form-label">Mô tả (VI)</label>
              <textarea class="form-textarea" name="desc_vi" rows="2" placeholder="Cà phê sữa truyền thống..."></textarea>
            </div>
            <div class="form-group" style="margin:0">
              <label class="form-label">Description (EN)</label>
              <textarea class="form-textarea" name="desc_en" rows="2" placeholder="Traditional Vietnamese..."></textarea>
            </div>
          </div>
          <!-- Tag -->
          <div class="form-row" style="margin-bottom:16px">
            <div class="form-group" style="margin:0">
              <label class="form-label">Tag nhãn (VI) <span style="color:#9ca3af;font-weight:400">tuỳ chọn</span></label>
              <input class="form-input" type="text" name="tag_vi" placeholder="Bán chạy / Mới / Yêu thích">
            </div>
            <div class="form-group" style="margin:0">
              <label class="form-label">Tag label (EN) <span style="color:#9ca3af;font-weight:400">optional</span></label>
              <input class="form-input" type="text" name="tag_en" placeholder="Best Seller / New / Favorite">
            </div>
          </div>
          <!-- Giá / Danh mục / Nổi bật -->
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:20px">
            <div class="form-group" style="margin:0">
              <label class="form-label">Giá (VNĐ) <span class="form-required">*</span></label>
              <input class="form-input" type="number" name="price" required min="1000" step="1000" placeholder="45000">
            </div>
            <div class="form-group" style="margin:0">
              <label class="form-label">Danh mục <span class="form-required">*</span></label>
              <select class="form-select" name="category" required>
                <% categories.forEach(c => { %>
                <option value="<%= c.id %>"><%= c.name_vi %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group" style="margin:0">
              <label class="form-label">Hiển thị nổi bật</label>
              <select class="form-select" name="featured">
                <option value="">Không</option>
                <option value="on">Có (hiện trang chủ)</option>
              </select>
            </div>
          </div>
          <!-- Submit -->
          <div style="display:flex;align-items:center;gap:12px">
            <button type="submit" class="btn btn-accent" id="submitBtn">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Thêm món & Sync GitHub
            </button>
            <span style="font-size:.78rem;color:#9ca3af">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="display:inline;vertical-align:middle;margin-right:3px" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              Tự động commit lên GitHub sau khi thêm
            </span>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Items Table -->
  <div class="admin-card">
    <div class="admin-card-header">
      <span class="admin-card-title">Danh sách món (<%= items.length %>)</span>
    </div>
    <% if (items.length === 0) { %>
    <div class="admin-card-body" style="text-align:center;padding:48px;color:#9ca3af">
      <p>Menu chưa có món nào. Thêm món đầu tiên phía trên.</p>
    </div>
    <% } else { %>
    <div style="overflow-x:auto">
      <table class="admin-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Tên VI / EN</th>
            <th>Danh mục</th>
            <th>Giá</th>
            <th>Tag</th>
            <th>Nổi bật</th>
            <th style="width:80px">Xóa</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach((item, idx) => { %>
          <tr>
            <td style="color:#9ca3af;font-size:.78rem"><%= idx + 1 %></td>
            <td>
              <div style="font-weight:600;font-size:.88rem"><%= item.name_vi %></div>
              <div style="font-size:.78rem;color:#9ca3af"><%= item.name_en %></div>
            </td>
            <td>
              <span class="badge badge-dark"><%= categories.find(c=>c.id===item.category)?.name_vi || item.category %></span>
            </td>
            <td style="font-weight:600"><%= item.price.toLocaleString('vi-VN') %>đ</td>
            <td style="font-size:.78rem;color:#6b7280"><%= item.tag_vi || '—' %></td>
            <td>
              <% if (item.featured) { %>
              <span style="display:inline-flex;align-items:center;gap:4px;font-size:.75rem;color:#d97706;font-weight:600">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                Nổi bật
              </span>
              <% } else { %>
              <span style="color:#d1d5db;font-size:.78rem">—</span>
              <% } %>
            </td>
            <td>
              <form action="/admin/menu/<%= item.id %>/delete" method="POST"
                onsubmit="return confirm('Xóa món \'<%= item.name_vi %>\'?\nHành động này sẽ đồng thời xóa trên GitHub.')">
                <button type="submit" class="btn btn-sm btn-danger">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
                  Xóa
                </button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<script>
function toggleForm() {
  const f = document.getElementById('addForm');
  const c = document.getElementById('formChevron');
  const open = f.style.display === 'block';
  f.style.display = open ? 'none' : 'block';
  c.style.transform = open ? '' : 'rotate(180deg)';
}
document.getElementById('menuAddForm')?.addEventListener('submit', function() {
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="animation:spin 1s linear infinite" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg> Đang lưu & sync...';
});
</script>
<style>
@keyframes spin { to { transform: rotate(360deg); } }
</style>

<%- include('../partials/admin-footer') %>
