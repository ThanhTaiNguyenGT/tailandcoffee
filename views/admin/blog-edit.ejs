<%- include('../partials/admin-header', { pageTitle: 'Blog' }) %>

<div class="adm-page-header">
  <div>
    <h1 class="adm-page-title">Sửa bài viết</h1>
    <p class="adm-page-subtitle"><%= post.title_vi %></p>
  </div>
  <div class="adm-page-actions">
    <a href="/blog/<%= post.slug %>?lang=vi" target="_blank" rel="noopener" class="adm-btn adm-btn-outline adm-btn-sm">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
      Xem bài viết
    </a>
    <a href="/admin/blog" class="adm-btn adm-btn-outline adm-btn-sm">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Quay lại Blog
    </a>
  </div>
</div>

<div class="adm-card">
  <div class="adm-card-header">
    <span class="adm-card-title">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      Nội dung bài viết
    </span>
    <span style="font-size:.72rem;color:var(--adm-text-3);font-family:monospace"><%= post.slug %></span>
  </div>
  <div class="adm-card-body">
    <form action="/admin/blog/<%= post.id %>/edit" method="POST" id="blogEditForm">
      <div class="adm-form-row">
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Tiêu đề (VI) <span class="adm-required">*</span></label>
          <input class="adm-input" type="text" name="title_vi" required value="<%= post.title_vi %>">
        </div>
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Title (EN) <span class="adm-required">*</span></label>
          <input class="adm-input" type="text" name="title_en" required value="<%= post.title_en %>">
        </div>
      </div>

      <div class="adm-form-row">
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Tóm tắt (VI)</label>
          <textarea class="adm-textarea" name="excerpt_vi" rows="2"><%= post.excerpt_vi %></textarea>
        </div>
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Excerpt (EN)</label>
          <textarea class="adm-textarea" name="excerpt_en" rows="2"><%= post.excerpt_en %></textarea>
        </div>
      </div>

      <div class="adm-form-row">
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Nội dung (VI) <span class="adm-label-opt">HTML được phép</span></label>
          <textarea class="adm-textarea" name="content_vi" rows="10" style="font-family:monospace;font-size:.82rem"><%= post.content_vi %></textarea>
        </div>
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Content (EN) <span class="adm-label-opt">HTML allowed</span></label>
          <textarea class="adm-textarea" name="content_en" rows="10" style="font-family:monospace;font-size:.82rem"><%= post.content_en %></textarea>
        </div>
      </div>

      <div class="adm-form-row-3">
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Danh mục (VI)</label>
          <input class="adm-input" type="text" name="category_vi" value="<%= post.category_vi %>">
        </div>
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Category (EN)</label>
          <input class="adm-input" type="text" name="category_en" value="<%= post.category_en %>">
        </div>
        <div class="adm-form-group" style="margin:0">
          <label class="adm-label">Tác giả</label>
          <input class="adm-input" type="text" name="author" value="<%= post.author %>">
        </div>
      </div>

      <div class="adm-form-group">
        <label class="adm-label">Hiển thị nổi bật</label>
        <select class="adm-select" name="featured" style="max-width:240px">
          <option value="" <%= !post.featured ? 'selected' : '' %>>Không</option>
          <option value="on" <%= post.featured ? 'selected' : '' %>>Có (hiện trang chủ)</option>
        </select>
      </div>

      <div style="display:flex;align-items:center;gap:12px;padding-top:12px;border-top:1px solid var(--adm-border);margin-top:8px">
        <button type="submit" class="adm-btn adm-btn-accent" id="submitBtn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Lưu thay đổi & Sync GitHub
        </button>
        <a href="/admin/blog" class="adm-btn adm-btn-ghost">Hủy</a>
      </div>
    </form>
  </div>
</div>

<script>
document.getElementById('blogEditForm')?.addEventListener('submit', function() {
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="animation:spin 1s linear infinite"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg> Đang lưu...';
});
</script>
<style>@keyframes spin { to { transform: rotate(360deg); } }</style>

<%- include('../partials/admin-footer') %>
