<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — TaiLand Cafe</title>
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="adm-body">
<div class="adm-login-page">
  <div class="adm-login-card">
    <div class="adm-login-logo">
      <div class="adm-login-logo-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>
      </div>
      <div>
        <div class="adm-login-logo-text">TaiLand</div>
        <div class="adm-login-logo-sub">Admin Panel</div>
      </div>
    </div>

    <p class="adm-login-title">Đăng nhập để quản lý</p>

    <% if (error && error.length > 0) { %>
    <div class="adm-flash adm-flash-error" role="alert" style="border-radius:10px;margin-bottom:20px">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span><%= error[0] %></span>
    </div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="adm-form-group">
        <label class="adm-label" for="username">Tài khoản</label>
        <input class="adm-input" type="text" id="username" name="username" required autocomplete="username" autofocus placeholder="admin">
      </div>
      <div class="adm-form-group">
        <label class="adm-label" for="password">Mật khẩu</label>
        <input class="adm-input" type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••">
      </div>
      <button type="submit" class="adm-btn adm-btn-accent adm-btn-lg" style="width:100%;justify-content:center;margin-top:8px">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Đăng nhập
      </button>
    </form>
    <div style="text-align:center;margin-top:20px">
      <a href="/?lang=vi" style="color:var(--adm-text-3);font-size:.8rem">← Về trang chủ</a>
    </div>
  </div>
</div>
</body>
</html>
